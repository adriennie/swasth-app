{
  "project": "Swasthya \u2014 Intelligent Pharmacy Network",
  "feature": "Feature 2 \u2014 Order Anomaly Detection",
  "model_type": "IsolationForest",
  "anomaly_features": [
    "qty_vs_mean",
    "qty_vs_median",
    "qty_vs_p95",
    "qty_vs_max",
    "qty_zscore",
    "order_value_log",
    "order_qty_log",
    "entity_mean_log",
    "entity_cv",
    "entity_p95_log",
    "entity_order_count",
    "mean_qty",
    "std_qty",
    "p95_qty",
    "order_month",
    "order_dow",
    "is_month_start",
    "is_quarter_end"
  ],
  "n_features": 18,
  "contamination": 0.05,
  "n_estimators": 300,
  "training_orders": 8295,
  "anomaly_count": 414,
  "metrics": {
    "precision": 0.9518,
    "recall": 0.9541,
    "f1": 0.953,
    "roc_auc": 0.9996
  },
  "severity_thresholds": {
    "CRITICAL": "iso_score < -0.20 OR qty_vs_mean > 8",
    "HIGH": "iso_score < -0.10 OR qty_vs_mean > 5",
    "MEDIUM": "flagged but below HIGH thresholds"
  },
  "anomaly_types_detectable": [
    "panic_bulk_order",
    "repeat_excess",
    "unusual_combo",
    "off_cycle_spike"
  ]
}